    "next": "13.1.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "swr": "^2.0.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^18.11.18",
    "@types/react": "^18.0.27",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "prisma": "4.9.0",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.6",
    "typescript": "^4.9.5",
    "vitest": "^0.34.6"
